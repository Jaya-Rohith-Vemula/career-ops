{
  "name": "job-pipeline",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "discover": "node discoveryAgent.js",
    "daily": "node dailyRunner.js",
    "export": "node exportJobs.js",
    "resume:c2c": "node resume/C2C/tailorResumeC2C.js",
    "resume:ft": "node resume/tailorResumeFromJD.js",
    "server": "node server/index.js",
    "ui:dev": "npm --prefix ui run dev",
    "dev": "concurrently -n server,ui -c blue,green \"npm:server\" \"npm:ui:dev\""
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}